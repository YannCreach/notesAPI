# ------------------------------------------------------------
# NotesAPI environment variables (Supabase-only)
# ------------------------------------------------------------

# Runtime
NODE_ENV=development
SERVER_PORT=3001

# CORS
ALLOWED_ORIGINS=http://localhost:8081
CLIENT_ORIGIN_URL=http://localhost:8081/

# Supabase (REQUIRED)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Required for backend admin operations (register, user metadata updates)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# External APIs (needed only for related endpoints)
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
HTTP_CLIENT_TIMEOUT_MS=5000

# Resend (email notifications for social feature)
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=noreply@yourdomain.com

# AWS S3 (photo storage)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=eu-west-3
S3_BUCKET=notesapi-photos
