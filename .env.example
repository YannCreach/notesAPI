# ------------------------------------------------------------
# NotesAPI environment variables (Supabase-only)
# ------------------------------------------------------------

# Runtime
NODE_ENV=development
SERVER_PORT=3001

# CORS
ALLOWED_ORIGINS=http://localhost:8081
CLIENT_ORIGIN_URL=http://localhost:8081/

# Supabase (REQUIRED)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Required for backend admin operations (register, user metadata updates)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# External APIs (needed only for related endpoints)
YELP_API_KEY=YOUR_YELP_API_KEY
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
HTTP_CLIENT_TIMEOUT_MS=5000
